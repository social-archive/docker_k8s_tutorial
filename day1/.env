# -----------------------------------------------------------------------
# 1일차 실습 환경변수
# compose.yml 에서 env_file: .env 로 참조된다.
# -----------------------------------------------------------------------

# PostgreSQL 컨테이너 설정
POSTGRES_DB=tododb
POSTGRES_USER=todo
POSTGRES_PASSWORD=todo1234

# Spring 애플리케이션이 읽는 DB 접속 환경변수
DB_HOST=postgres
DB_PORT=5432
DB_NAME=tododb
DB_USER=todo
DB_PASSWORD=todo1234
